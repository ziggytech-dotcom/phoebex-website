{
  "version": 3,
  "pages404": true,
  "caseSensitive": false,
  "basePath": "",
  "redirects": [
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "internal": true,
      "statusCode": 308,
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$"
    }
  ],
  "headers": [],
  "rewrites": {
    "beforeFiles": [],
    "afterFiles": [],
    "fallback": []
  },
  "dynamicRoutes": [],
  "staticRoutes": [
    {
      "page": "/",
      "regex": "^/(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/(?:/)?$"
    },
    {
      "page": "/_not-found",
      "regex": "^/_not\\-found(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/_not\\-found(?:/)?$"
    },
    {
      "page": "/contact",
      "regex": "^/contact(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/contact(?:/)?$"
    },
    {
      "page": "/docs",
      "regex": "^/docs(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/docs(?:/)?$"
    },
    {
      "page": "/for-corporate",
      "regex": "^/for\\-corporate(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/for\\-corporate(?:/)?$"
    },
    {
      "page": "/for-insurance",
      "regex": "^/for\\-insurance(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/for\\-insurance(?:/)?$"
    },
    {
      "page": "/for-investors",
      "regex": "^/for\\-investors(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/for\\-investors(?:/)?$"
    },
    {
      "page": "/for-real-estate",
      "regex": "^/for\\-real\\-estate(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/for\\-real\\-estate(?:/)?$"
    },
    {
      "page": "/methodology",
      "regex": "^/methodology(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/methodology(?:/)?$"
    },
    {
      "page": "/other-industries",
      "regex": "^/other\\-industries(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/other\\-industries(?:/)?$"
    },
    {
      "page": "/pricing",
      "regex": "^/pricing(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/pricing(?:/)?$"
    },
    {
      "page": "/privacy",
      "regex": "^/privacy(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/privacy(?:/)?$"
    },
    {
      "page": "/terms",
      "regex": "^/terms(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/terms(?:/)?$"
    }
  ],
  "dataRoutes": [],
  "rsc": {
    "header": "rsc",
    "varyHeader": "rsc, next-router-state-tree, next-router-prefetch, next-router-segment-prefetch",
    "prefetchHeader": "next-router-prefetch",
    "didPostponeHeader": "x-nextjs-postponed",
    "contentTypeHeader": "text/x-component",
    "suffix": ".rsc",
    "prefetchSuffix": ".prefetch.rsc",
    "prefetchSegmentHeader": "next-router-segment-prefetch",
    "prefetchSegmentSuffix": ".segment.rsc",
    "prefetchSegmentDirSuffix": ".segments"
  },
  "rewriteHeaders": {
    "pathHeader": "x-nextjs-rewritten-path",
    "queryHeader": "x-nextjs-rewritten-query"
  }
}